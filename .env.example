# 百度图库爬虫配置文件
# 复制此文件为 .env 并填入真实值
# ⚠️ 严禁将 .env 文件提交到 Git！

# 下载配置
DOWNLOAD_PATH=./downloads
MAX_THREADS=5
CHUNK_SIZE=8192

# 重试配置
MAX_RETRIES=3
RETRY_DELAY=1.0
TIMEOUT=30

# 日志配置
LOG_PATH=./logs
LOG_LEVEL=INFO

# 状态配置
STATE_PATH=./.state

# 百度 Cookie（强烈推荐配置，可获取真实图片）
# ⚠️ 获取方法:
#   1. 打开 https://image.baidu.com/
#   2. 按 F12 打开开发者工具
#   3. 搜索任意关键词（如"派蒙"）
#   4. 在 Network 标签找到请求，复制 Request Headers 中的 Cookie
#   5. 粘贴到下方
# ⚠️ 格式：BAIDUID=***; BDUSS=***; STOKEN=***; ...
# ⚠️ Cookie 会过期，建议定期更新
# ⚠️ 注意：此文件已脱敏，真实 Cookie 请自行获取
BAIDU_COOKIE=YOUR_BAIDU_COOKIE_HERE
